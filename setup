#!/usr/bin/env bash
# Ubuntu Face Login — Setup entry point
# Launches the GTK4 setup wizard, bootstrapping python3-gi if needed.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Prefer the installed venv if present, then fall back to system python
if [[ -x /opt/ubuntu-face-login/.venv/bin/python ]]; then
    PYTHON=/opt/ubuntu-face-login/.venv/bin/python
elif [[ -x "${SCRIPT_DIR}/.venv2/bin/python" ]]; then
    PYTHON="${SCRIPT_DIR}/.venv2/bin/python"
elif [[ -x "${SCRIPT_DIR}/.venv/bin/python" ]]; then
    PYTHON="${SCRIPT_DIR}/.venv/bin/python"
else
    PYTHON=python3
fi

# Check for GTK4 + PyGObject (system package — not pip-installable)
if ! python3 -c "import gi; gi.require_version('Gtk','4.0')" 2>/dev/null; then
    echo "Installing GTK4 Python bindings..."
    sudo apt-get install -y python3-gi gir1.2-gtk-4.0 gir1.2-adw-1 2>/dev/null \
        || { echo "Could not install GTK4 bindings. Run: sudo apt install python3-gi gir1.2-gtk-4.0 gir1.2-adw-1"; exit 1; }
fi

# For venvs that don't have system-site-packages, use system python for the wizard
# (gi is always a system package)
if ! $PYTHON -c "import gi" 2>/dev/null; then
    PYTHON=python3
fi

PYTHONPATH="${SCRIPT_DIR}/src${PYTHONPATH:+:$PYTHONPATH}" \
    exec $PYTHON "${SCRIPT_DIR}/setup-wizard.py" "$@"
